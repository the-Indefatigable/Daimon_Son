# ---------- LLM ----------
ANTHROPIC_API_KEY=
# Optional fallback / comparison
OPENAI_API_KEY=

# ---------- Business APIs (Phase 1 optional — tools skip gracefully if empty) ----------
STRIPE_SECRET_KEY=
GOOGLE_CONSOLE_CREDENTIALS=
SENTRY_AUTH_TOKEN=
VERCEL_TOKEN=

# ---------- Search (Phase 3) ----------
# Get a key at tavily.com — free tier is 1,000 searches/month, no card needed.
TAVILY_API_KEY=

# ---------- GitHub (Phase 2: READ-ONLY) ----------
# Create at github.com/settings/tokens. Classic PAT works — scope: `repo` read-only,
# or `public_repo` if you only want DAIMON seeing public stuff. Fine-grained PAT
# with Contents:read on specific repos also works.
GITHUB_PAT=
# Optional comma-separated list to narrow DAIMON's attention. Empty = let it
# discover via the API itself.
GITHUB_REPOS=

# ---------- Social Media ----------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ---------- Income Tools (Phase 4) ----------
ETHEREUM_PRIVATE_KEY=
POLYMARKET_API_KEY=

# ---------- Notifications ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Infrastructure ----------
DATABASE_URL=sqlite:///data/daimon.db
RAILWAY_TOKEN=
CYCLE_INTERVAL_MINUTES=30
INITIAL_BALANCE=20.0
# Estimated fixed infra cost per month (Railway, etc). API costs are tracked live.
MONTHLY_FIXED_BURN=5.0
